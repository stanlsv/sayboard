    "NSMicrophoneUsageDescription": {
      "comment": "Privacy - Microphone Usage Description",
      "localizations": {
        "cs": { "stringUnit": { "state": "needs_review", "value": "Sayboard potřebuje přístup k mikrofonu pro převod řeči na text. Veškeré zpracování probíhá na zařízení." } },
        "da": { "stringUnit": { "state": "needs_review", "value": "Sayboard har brug for mikrofonadgang for at omdanne din tale til tekst. Al behandling sker på enheden." } },
        "de": { "stringUnit": { "state": "needs_review", "value": "Sayboard benötigt Mikrofonzugriff, um Ihre Sprache in Text umzuwandeln. Die gesamte Verarbeitung erfolgt auf dem Gerät." } },
        "el": { "stringUnit": { "state": "needs_review", "value": "Το Sayboard χρειάζεται πρόσβαση στο μικρόφωνο για να μετατρέψει την ομιλία σας σε κείμενο. Όλη η επεξεργασία γίνεται στη συσκευή." } },
        "en": { "stringUnit": { "state": "translated", "value": "Sayboard needs microphone access to convert your speech to text. All processing happens on-device." } },
        "es": { "stringUnit": { "state": "needs_review", "value": "Sayboard necesita acceso al micrófono para convertir tu voz en texto. Todo el procesamiento se realiza en el dispositivo." } },
        "fi": { "stringUnit": { "state": "needs_review", "value": "Sayboard tarvitsee mikrofonin käyttöoikeuden puheesi muuntamiseksi tekstiksi. Kaikki käsittely tapahtuu laitteella." } },
        "fr": { "stringUnit": { "state": "needs_review", "value": "Sayboard a besoin d'accéder au microphone pour convertir votre voix en texte. Tout le traitement se fait sur l'appareil." } },
        "hi": { "stringUnit": { "state": "needs_review", "value": "Sayboard को आपकी आवाज़ को टेक्स्ट में बदलने के लिए माइक्रोफ़ोन एक्सेस की ज़रूरत है। सारी प्रोसेसिंग डिवाइस पर होती है।" } },
        "hu": { "stringUnit": { "state": "needs_review", "value": "A Sayboardnak mikrofon-hozzáférésre van szüksége a beszéd szöveggé alakításához. Minden feldolgozás az eszközön történik." } },
        "it": { "stringUnit": { "state": "needs_review", "value": "Sayboard ha bisogno dell'accesso al microfono per convertire la tua voce in testo. Tutta l'elaborazione avviene sul dispositivo." } },
        "ja": { "stringUnit": { "state": "needs_review", "value": "Sayboardは音声をテキストに変換するためにマイクへのアクセスが必要です。すべての処理はデバイス上で行われます。" } },
        "ko": { "stringUnit": { "state": "needs_review", "value": "Sayboard는 음성을 텍스트로 변환하기 위해 마이크 접근 권한이 필요합니다. 모든 처리는 기기에서 이루어집니다." } },
        "nl": { "stringUnit": { "state": "needs_review", "value": "Sayboard heeft microfoontoegang nodig om je spraak naar tekst om te zetten. Alle verwerking gebeurt op het apparaat." } },
        "no": { "stringUnit": { "state": "needs_review", "value": "Sayboard trenger mikrofontilgang for å gjøre tale om til tekst. All behandling skjer på enheten." } },
        "pl": { "stringUnit": { "state": "needs_review", "value": "Sayboard potrzebuje dostępu do mikrofonu, aby zamienić mowę na tekst. Całe przetwarzanie odbywa się na urządzeniu." } },
        "pt": { "stringUnit": { "state": "needs_review", "value": "O Sayboard precisa de acesso ao microfone para converter sua fala em texto. Todo o processamento ocorre no dispositivo." } },
        "ro": { "stringUnit": { "state": "needs_review", "value": "Sayboard are nevoie de acces la microfon pentru a converti vocea ta în text. Toată procesarea are loc pe dispozitiv." } },
        "ru": { "stringUnit": { "state": "translated", "value": "Sayboard нужен доступ к микрофону для преобразования речи в текст. Вся обработка происходит на устройстве." } },
        "sk": { "stringUnit": { "state": "needs_review", "value": "Sayboard potrebuje prístup k mikrofónu na prevod reči na text. Všetko spracovanie prebieha na zariadení." } },
        "sv": { "stringUnit": { "state": "needs_review", "value": "Sayboard behöver mikrofonåtkomst för att omvandla ditt tal till text. All bearbetning sker på enheten." } },
        "tr": { "stringUnit": { "state": "needs_review", "value": "Sayboard, konuşmanızı metne dönüştürmek için mikrofon erişimine ihtiyaç duyar. Tüm işlemler cihazda gerçekleşir." } },
        "uk": { "stringUnit": { "state": "needs_review", "value": "Sayboard потребує доступу до мікрофона для перетворення мовлення на текст. Уся обробка відбувається на пристрої." } },
        "zh": { "stringUnit": { "state": "needs_review", "value": "Sayboard需要麦克风权限来将语音转换为文字。所有处理均在设备上完成。" } }
      }
    },
    "NSSpeechRecognitionUsageDescription": {
      "extractionState": "stale",
      "localizations": {
        "cs": { "stringUnit": { "state": "needs_review", "value": "Sayboard používá rozpoznávání řeči k přepisu vašeho hlasu. Veškeré zpracování probíhá na zařízení — zvuk nikdy neopustí vaše zařízení." } },
        "da": { "stringUnit": { "state": "needs_review", "value": "Sayboard bruger talegenkendelse til at transskribere din stemme. Al behandling sker på enheden — din lyd forlader aldrig din enhed." } },
        "de": { "stringUnit": { "state": "needs_review", "value": "Sayboard verwendet Spracherkennung zur Transkription Ihrer Stimme. Die gesamte Verarbeitung erfolgt auf dem Gerät — Ihre Audiodaten verlassen niemals Ihr Gerät." } },
        "el": { "stringUnit": { "state": "needs_review", "value": "Το Sayboard χρησιμοποιεί αναγνώριση ομιλίας για τη μεταγραφή της φωνής σας. Όλη η επεξεργασία γίνεται στη συσκευή — ο ήχος σας δεν φεύγει ποτέ από τη συσκευή σας." } },
        "en": { "stringUnit": { "state": "translated", "value": "Sayboard uses speech recognition to transcribe your voice. All processing happens on-device — your audio never leaves your device." } },
        "es": { "stringUnit": { "state": "needs_review", "value": "Sayboard utiliza reconocimiento de voz para transcribir tu voz. Todo el procesamiento se realiza en el dispositivo — tu audio nunca sale de tu dispositivo." } },
        "fi": { "stringUnit": { "state": "needs_review", "value": "Sayboard käyttää puheentunnistusta äänesi litterointiin. Kaikki käsittely tapahtuu laitteella — äänitiedostosi eivät koskaan poistu laitteeltasi." } },
        "fr": { "stringUnit": { "state": "needs_review", "value": "Sayboard utilise la reconnaissance vocale pour transcrire votre voix. Tout le traitement se fait sur l'appareil — votre audio ne quitte jamais votre appareil." } },
        "hi": { "stringUnit": { "state": "needs_review", "value": "Sayboard आपकी आवाज़ को ट्रांसक्राइब करने के लिए स्पीच रिकग्निशन का उपयोग करता है। सारी प्रोसेसिंग डिवाइस पर होती है — आपका ऑडियो कभी भी आपके डिवाइस से बाहर नहीं जाता।" } },
        "hu": { "stringUnit": { "state": "needs_review", "value": "A Sayboard beszédfelismerést használ a hang átírásához. Minden feldolgozás az eszközön történik — a hangfelvétel soha nem hagyja el az eszközét." } },
        "it": { "stringUnit": { "state": "needs_review", "value": "Sayboard utilizza il riconoscimento vocale per trascrivere la tua voce. Tutta l'elaborazione avviene sul dispositivo — il tuo audio non lascia mai il tuo dispositivo." } },
        "ja": { "stringUnit": { "state": "needs_review", "value": "Sayboardは音声認識を使用して音声を文字起こしします。すべての処理はデバイス上で行われます。音声データがデバイスの外に出ることはありません。" } },
        "ko": { "stringUnit": { "state": "needs_review", "value": "Sayboard는 음성 인식을 사용하여 음성을 텍스트로 변환합니다. 모든 처리는 기기에서 이루어지며, 오디오가 기기 밖으로 전송되지 않습니다." } },
        "nl": { "stringUnit": { "state": "needs_review", "value": "Sayboard gebruikt spraakherkenning om je stem te transcriberen. Alle verwerking gebeurt op het apparaat — je audio verlaat nooit je apparaat." } },
        "no": { "stringUnit": { "state": "needs_review", "value": "Sayboard bruker talegjenkjenning for å transkribere stemmen din. All behandling skjer på enheten — lyden din forlater aldri enheten din." } },
        "pl": { "stringUnit": { "state": "needs_review", "value": "Sayboard używa rozpoznawania mowy do transkrypcji głosu. Całe przetwarzanie odbywa się na urządzeniu — dźwięk nigdy nie opuszcza urządzenia." } },
        "pt": { "stringUnit": { "state": "needs_review", "value": "O Sayboard usa reconhecimento de fala para transcrever sua voz. Todo o processamento ocorre no dispositivo — seu áudio nunca sai do dispositivo." } },
        "ro": { "stringUnit": { "state": "needs_review", "value": "Sayboard folosește recunoașterea vocală pentru a transcrie vocea ta. Toată procesarea are loc pe dispozitiv — audio-ul tău nu părăsește niciodată dispozitivul." } },
        "ru": { "stringUnit": { "state": "translated", "value": "Sayboard использует распознавание речи для транскрибации голоса. Вся обработка происходит на устройстве — аудио никогда не покидает ваше устройство." } },
        "sk": { "stringUnit": { "state": "needs_review", "value": "Sayboard používa rozpoznávanie reči na prepis vášho hlasu. Všetko spracovanie prebieha na zariadení — váš zvuk nikdy neopustí vaše zariadenie." } },
        "sv": { "stringUnit": { "state": "needs_review", "value": "Sayboard använder taligenkänning för att transkribera din röst. All bearbetning sker på enheten — ditt ljud lämnar aldrig din enhet." } },
        "tr": { "stringUnit": { "state": "needs_review", "value": "Sayboard, sesinizi metne dönüştürmek için konuşma tanıma kullanır. Tüm işlemler cihazda gerçekleşir — ses kaydınız cihazınızdan asla çıkmaz." } },
        "uk": { "stringUnit": { "state": "needs_review", "value": "Sayboard використовує розпізнавання мовлення для транскрибації голосу. Уся обробка відбувається на пристрої — ваше аудіо ніколи не залишає ваш пристрій." } },
        "zh": { "stringUnit": { "state": "needs_review", "value": "Sayboard使用语音识别来转录您的语音。所有处理均在设备上完成，您的音频永远不会离开您的设备。" } }
      }
    }
  },
  "version": "1.0"
}
