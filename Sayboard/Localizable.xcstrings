        },
        "hi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "पुनर्लेखन, पुनर्स्वरूपण और अन्य पाठ क्रियाओं के लिए कीबोर्ड पर AI बटन जोड़ता है।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "needs_review",
