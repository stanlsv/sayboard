    "Could not reach model server. Check your connection and try again.": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось связаться с сервером моделей. Проверьте подключение и попробуйте снова."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Server modelů nedostupný. Zkontrolujte připojení a zkuste to znovu."
          }
        },
        "da": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Kunne ikke nå modelserveren. Kontrollér din forbindelse og prøv igen."
          }
        },
        "de": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Modellserver nicht erreichbar. Überprüfen Sie Ihre Verbindung und versuchen Sie es erneut."
          }
        },
        "el": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Δεν ήταν δυνατή η σύνδεση με τον διακομιστή μοντέλων. Ελέγξτε τη σύνδεσή σας και δοκιμάστε ξανά."
          }
        },
        "es": {
          "stringUnit": {
            "state": "needs_review",
            "value": "No se pudo conectar al servidor de modelos. Comprueba tu conexión e inténtalo de nuevo."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Mallipalvelinta ei tavoitettu. Tarkista yhteytesi ja yritä uudelleen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Impossible de joindre le serveur de modèles. Vérifiez votre connexion et réessayez."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "मॉडल सर्वर तक नहीं पहुँच सका। अपना कनेक्शन जाँचें और पुनः प्रयास करें।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Nem sikerült elérni a modellszervert. Ellenőrizze a kapcsolatát, és próbálja újra."
          }
        },
        "it": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Impossibile raggiungere il server dei modelli. Controlla la connessione e riprova."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "モデルサーバーに接続できません。接続を確認してもう一度お試しください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "needs_review",
            "value": "모델 서버에 연결할 수 없습니다. 연결을 확인하고 다시 시도하세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Modelserver niet bereikbaar. Controleer je verbinding en probeer het opnieuw."
          }
        },
        "no": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Kunne ikke nå modellserveren. Sjekk tilkoblingen og prøv igjen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Nie można połączyć się z serwerem modeli. Sprawdź połączenie i spróbuj ponownie."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Não foi possível acessar o servidor de modelos. Verifique sua conexão e tente novamente."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Nu s-a putut contacta serverul de modele. Verifică conexiunea și încearcă din nou."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Server modelov nedostupný. Skontrolujte pripojenie a skúste to znova."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Kunde inte nå modellservern. Kontrollera din anslutning och försök igen."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Model sunucusuna ulaşılamadı. Bağlantınızı kontrol edip tekrar deneyin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Не вдалося звʼязатися з сервером моделей. Перевірте зʼєднання та спробуйте знову."
          }
        },
        "zh": {
          "stringUnit": {
            "state": "needs_review",
            "value": "无法连接模型服务器。请检查网络连接后重试。"
          }
        }
      }
    },
    "Create snippets to auto-replace phrases when you dictate. Say the trigger phrase, and the replacement text is inserted instead.": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Создайте сниппеты для автозамены фраз при диктовке. Произнесите триггерную фразу, и вместо неё будет вставлен текст замены."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Vytvořte úryvky pro automatické nahrazení frází při diktování. Řekněte spouštěcí frázi a místo ní se vloží náhradní text."
          }
        },
        "da": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Opret uddrag til automatisk erstatning af sætninger, når du dikterer. Sig udløsersætningen, og erstatningsteksten indsættes i stedet."
          }
        },
        "de": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Erstellen Sie Snippets zum automatischen Ersetzen von Phrasen beim Diktieren. Sagen Sie die Auslösephrase, und der Ersetzungstext wird eingefügt."
          }
        },
        "el": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Δημιουργήστε αποσπάσματα για αυτόματη αντικατάσταση φράσεων κατά την υπαγόρευση. Πείτε τη φράση ενεργοποίησης και εισάγεται το κείμενο αντικατάστασης."
          }
        },
        "es": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Crea fragmentos para reemplazar frases automáticamente al dictar. Di la frase de activación y se insertará el texto de reemplazo."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Luo pätkiä fraasien automaattiseen korvaamiseen sanellessa. Sano laukaisufraasi, ja korvaava teksti lisätään sen sijaan."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Créez des extraits pour remplacer automatiquement des phrases lors de la dictée. Dites la phrase déclencheur et le texte de remplacement est inséré."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "डिक्टेट करते समय वाक्यांशों को स्वतः बदलने के लिए स्निपेट बनाएँ। ट्रिगर वाक्यांश बोलें, और उसके बदले प्रतिस्थापन पाठ डाला जाएगा।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Hozzon létre kódrészleteket a kifejezések automatikus cseréjéhez diktáláskor. Mondja ki az indító kifejezést, és a csere szöveg kerül beillesztésre."
          }
        },
        "it": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Crea snippet per sostituire automaticamente le frasi durante la dettatura. Pronuncia la frase di attivazione e il testo sostitutivo viene inserito."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "ディクテーション時にフレーズを自動置換するスニペットを作成します。トリガーフレーズを言うと、代替テキストが挿入されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "needs_review",
            "value": "받아쓰기 시 자동으로 구문을 대체하는 스니펫을 만듭니다. 트리거 구문을 말하면 대체 텍스트가 삽입됩니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Maak fragmenten om zinsdelen automatisch te vervangen bij dicteren. Zeg de triggerzin en de vervangende tekst wordt ingevoegd."
          }
        },
        "no": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Opprett utdrag for å automatisk erstatte fraser når du dikterer. Si utløserfrasen, og erstatningsteksten settes inn i stedet."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Twórz fragmenty do automatycznego zastępowania fraz podczas dyktowania. Powiedz frazę wyzwalającą, a tekst zastępczy zostanie wstawiony."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Crie trechos para substituir frases automaticamente ao ditar. Diga a frase de ativação e o texto de substituição será inserido."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Creați fragmente pentru înlocuirea automată a expresiilor la dictare. Spuneți expresia de declanșare și textul de înlocuire este inserat."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Vytvorte úryvky na automatické nahradenie fráz pri diktovaní. Povedzte spúšťaciu frázu a namiesto nej sa vloží náhradný text."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Skapa utdrag för att automatiskt ersätta fraser när du dikterar. Säg utlösarfrasen så infogas ersättningstexten."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Dikte ederken ifadeleri otomatik olarak değiştirmek için parçacıklar oluşturun. Tetikleyici ifadeyi söyleyin ve yerine değiştirme metni eklenir."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Створюйте фрагменти для автоматичної заміни фраз під час диктування. Скажіть тригерну фразу, і замість неї буде вставлений текст заміни."
          }
        },
        "zh": {
          "stringUnit": {
            "state": "needs_review",
            "value": "创建片段以在听写时自动替换短语。说出触发短语，替换文本将自动插入。"
          }
        }
      }
    },
