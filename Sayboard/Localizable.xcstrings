    "Adds an AI button to the keyboard for rewriting, reformatting, and other text actions.": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Добавляет кнопку ИИ на клавиатуру для перефразирования, форматирования и других действий с текстом."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Přidá na klávesnici tlačítko AI pro přepisování, přeformátování a další textové akce."
          }
        },
        "da": {
          "stringUnit": {
            "state": "needs_review",
