          }
        },
        "el": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Προσθέτει ένα κουμπί AI στο πληκτρολόγιο για επαναγραφή, αναδιαμόρφωση και άλλες ενέργειες κειμένου."
          }
        },
        "es": {
