    "Higher quality than 1B models. English-focused, slower processing.": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Качественнее моделей на 1B. Для английского, медленнее обработка."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Vyšší kvalita než modely 1B. Zaměřeno na angličtinu, pomalejší zpracování."
          }
        },
        "da": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Højere kvalitet end 1B-modeller. Engelskfokuseret, langsommere behandling."
          }
        },
        "de": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Höhere Qualität als 1B-Modelle. Auf Englisch fokussiert, langsamere Verarbeitung."
          }
        },
        "el": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Υψηλότερη ποιότητα από μοντέλα 1B. Εστιασμένο στα αγγλικά, πιο αργή επεξεργασία."
          }
        },
        "es": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Mayor calidad que los modelos 1B. Enfocado en inglés, procesamiento más lento."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Korkeampi laatu kuin 1B-mallit. Englantipainotteinen, hitaampi käsittely."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Qualité supérieure aux modèles 1B. Axé sur l'anglais, traitement plus lent."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "1B मॉडल से अधिक गुणवत्ता। अंग्रेज़ी-केंद्रित, धीमा प्रसंस्करण।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Magasabb minőség, mint az 1B modellek. Angolra fókuszált, lassabb feldolgozás."
          }
        },
        "it": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Qualità superiore ai modelli 1B. Focalizzato sull'inglese, elaborazione più lenta."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "1Bモデルより高品質。英語中心、処理速度は遅め。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "needs_review",
            "value": "1B 모델보다 높은 품질. 영어 중심, 처리 속도 느림."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Hogere kwaliteit dan 1B-modellen. Engelsgericht, langzamere verwerking."
          }
        },
        "no": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Høyere kvalitet enn 1B-modeller. Engelskfokusert, tregere behandling."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Wyższa jakość niż modele 1B. Skupiony na angielskim, wolniejsze przetwarzanie."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Qualidade superior aos modelos 1B. Focado em inglês, processamento mais lento."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Calitate mai bună decât modelele 1B. Axat pe engleză, procesare mai lentă."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Vyššia kvalita ako modely 1B. Zameraný na angličtinu, pomalšie spracovanie."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Högre kvalitet än 1B-modeller. Engelskfokuserad, långsammare bearbetning."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "1B modellerden daha yüksek kalite. İngilizce odaklı, daha yavaş işleme."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Вища якість, ніж моделі 1B. Орієнтований на англійську, повільніша обробка."
          }
        },
        "zh": {
          "stringUnit": {
            "state": "needs_review",
            "value": "比1B模型质量更高。以英语为主，处理速度较慢。"
          }
        }
      }
    },
    "Highest quality model. Best multilingual support, but slowest.": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Лучшее качество среди всех моделей. Лучшая мультиязычная поддержка, но самая медленная."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "needs_review",
