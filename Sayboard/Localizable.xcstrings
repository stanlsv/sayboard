    "Small English model. Better than Moonshine Tiny, no streaming.": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Небольшая модель для английского. Точнее Moonshine Tiny, без потока."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Malý anglický model. Lepší než Moonshine Tiny, bez streamování."
          }
        },
        "da": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Lille engelsk model. Bedre end Moonshine Tiny, ingen streaming."
          }
        },
        "de": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Kleines englisches Modell. Besser als Moonshine Tiny, kein Streaming."
          }
        },
        "el": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Μικρό αγγλικό μοντέλο. Καλύτερο από το Moonshine Tiny, χωρίς streaming."
          }
        },
        "es": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Modelo pequeño en inglés. Mejor que Moonshine Tiny, sin streaming."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Pieni englanninkielinen malli. Parempi kuin Moonshine Tiny, ei suoratoistoa."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Petit modèle anglais. Meilleur que Moonshine Tiny, pas de streaming."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "छोटा अंग्रेज़ी मॉडल। Moonshine Tiny से बेहतर, कोई स्ट्रीमिंग नहीं।"
          }
