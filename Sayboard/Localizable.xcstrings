    "Sayboard can't see your installed apps. Search is performed in the App Store, so make sure you select the right app.": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Sayboard не видит ваши установленные приложения. Поиск идёт через App Store, поэтому убедитесь, что выбрали нужное приложение."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Sayboard nevidí vaše nainstalované aplikace. Vyhledávání se provádí v App Store, proto se ujistěte, že vyberete správnou aplikaci."
          }
        },
        "da": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Sayboard kan ikke se dine installerede apps. Søgning udføres i App Store, så sørg for at vælge den rigtige app."
          }
        },
        "de": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Sayboard kann Ihre installierten Apps nicht sehen. Die Suche wird im App Store durchgeführt. Stellen Sie sicher, dass Sie die richtige App auswählen."
          }
        },
        "el": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Το Sayboard δεν μπορεί να δει τις εγκατεστημένες εφαρμογές σας. Η αναζήτηση γίνεται στο App Store, οπότε βεβαιωθείτε ότι επιλέγετε τη σωστή εφαρμογή."
          }
        },
        "es": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Sayboard no puede ver tus apps instaladas. La búsqueda se realiza en el App Store, así que asegúrate de seleccionar la app correcta."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Sayboard ei näe asennettuja sovelluksiasi. Haku tehdään App Storessa, joten varmista, että valitset oikean sovelluksen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Sayboard ne peut pas voir vos applications installées. La recherche est effectuée dans l'App Store, assurez-vous donc de sélectionner la bonne application."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Sayboard आपके इंस्टॉल किए गए ऐप्स नहीं देख सकता। खोज App Store में की जाती है, इसलिए सुनिश्चित करें कि आप सही ऐप चुनें।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "needs_review",
            "value": "A Sayboard nem látja a telepített alkalmazásait. A keresés az App Store-ban történik, ezért győződjön meg róla, hogy a megfelelő alkalmazást választja ki."
          }
        },
        "it": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Sayboard non può vedere le tue app installate. La ricerca viene eseguita nell'App Store, quindi assicurati di selezionare l'app corretta."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Sayboardはインストール済みのアプリを見ることはできません。検索はApp Storeで行われるため、正しいアプリを選択してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Sayboard는 설치된 앱을 볼 수 없습니다. 검색은 App Store에서 수행되므로 올바른 앱을 선택하세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Sayboard kan uw geïnstalleerde apps niet zien. De zoekopdracht wordt uitgevoerd in de App Store, dus zorg ervoor dat u de juiste app selecteert."
          }
        },
        "no": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Sayboard kan ikke se dine installerte apper. Søk utføres i App Store, så sørg for at du velger riktig app."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Sayboard nie widzi zainstalowanych aplikacji. Wyszukiwanie odbywa się w App Store, więc upewnij się, że wybierasz właściwą aplikację."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "needs_review",
            "value": "O Sayboard não pode ver seus apps instalados. A busca é feita na App Store, então certifique-se de selecionar o app correto."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Sayboard nu poate vedea aplicațiile instalate. Căutarea se face în App Store, așa că asigurați-vă că selectați aplicația corectă."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Sayboard nevidí vaše nainštalované aplikácie. Vyhľadávanie sa vykonáva v App Store, preto sa uistite, že vyberiete správnu aplikáciu."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Sayboard kan inte se dina installerade appar. Sökningen utförs i App Store, så se till att du väljer rätt app."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Sayboard yüklü uygulamalarınızı göremez. Arama App Store'da yapılır, bu yüzden doğru uygulamayı seçtiğinizden emin olun."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Sayboard не бачить встановлених додатків. Пошук виконується в App Store, тому переконайтеся, що ви вибираєте правильний додаток."
          }
        },
        "zh": {
          "stringUnit": {
