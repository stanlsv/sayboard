    "Allows the keyboard to start dictation instantly, without switching to the app. The orange dot in the status bar is normal — it means the mic session is active.": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Позволяет клавиатуре начинать диктовку мгновенно, без переключения в приложение. Оранжевая точка в строке состояния — это нормально, она означает, что сессия микрофона активна."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Umožňuje klávesnici okamžitě zahájit diktování bez přepnutí do aplikace. Oranžová tečka ve stavovém řádku je normální — znamená, že relace mikrofonu je aktivní."
          }
        },
        "da": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Giver tastaturet mulighed for at starte diktering øjeblikkeligt uden at skifte til appen. Den orange prik i statuslinjen er normal — den betyder, at mikrofonsessionen er aktiv."
          }
        },
        "de": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Ermöglicht der Tastatur, die Diktierfunktion sofort zu starten, ohne zur App zu wechseln. Der orangefarbene Punkt in der Statusleiste ist normal — er bedeutet, dass die Mikrofonsitzung aktiv ist."
          }
        },
        "el": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Επιτρέπει στο πληκτρολόγιο να ξεκινά τη υπαγόρευση αμέσως, χωρίς εναλλαγή στην εφαρμογή. Η πορτοκαλί τελεία στη γραμμή κατάστασης είναι κανονική — σημαίνει ότι η συνεδρία μικροφώνου είναι ενεργή."
          }
        },
        "es": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Permite al teclado iniciar el dictado instantáneamente, sin cambiar a la app. El punto naranja en la barra de estado es normal — significa que la sesión del micrófono está activa."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Mahdollistaa näppäimistön sanelun aloittamisen heti ilman sovellukseen siirtymistä. Oranssi piste tilapalkissa on normaali — se tarkoittaa, että mikrofonistunto on aktiivinen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Permet au clavier de démarrer la dictée instantanément, sans basculer vers l'application. Le point orange dans la barre d'état est normal — il signifie que la session du micro est active."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "कीबोर्ड को ऐप पर स्विच किए बिना तुरंत डिक्टेशन शुरू करने देता है। स्टेटस बार में नारंगी बिंदु सामान्य है — इसका मतलब है कि माइक सत्र सक्रिय है।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Lehetővé teszi, hogy a billentyűzet azonnal elindítsa a diktálást, az alkalmazásra váltás nélkül. A narancssárga pont az állapotsorban normális — azt jelenti, hogy a mikrofon munkamenet aktív."
          }
        },
        "it": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Permette alla tastiera di avviare la dettatura istantaneamente, senza passare all'app. Il punto arancione nella barra di stato è normale — significa che la sessione del microfono è attiva."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "アプリに切り替えることなく、キーボードから即座にディクテーションを開始できます。ステータスバーのオレンジ色の点は正常です — マイクセッションがアクティブであることを意味します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "needs_review",
            "value": "앱으로 전환하지 않고 키보드에서 바로 받아쓰기를 시작할 수 있습니다. 상태 표시줄의 주황색 점은 정상입니다 — 마이크 세션이 활성 상태임을 의미합니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Hiermee kan het toetsenbord direct dicteren starten, zonder naar de app te schakelen. De oranje stip in de statusbalk is normaal — het betekent dat de microfoonsessie actief is."
          }
        },
        "no": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Lar tastaturet starte diktering umiddelbart, uten å bytte til appen. Den oransje prikken i statuslinjen er normal — den betyr at mikrofonøkten er aktiv."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Pozwala klawiaturze natychmiast rozpocząć dyktowanie bez przełączania do aplikacji. Pomarańczowa kropka na pasku stanu jest normalna — oznacza, że sesja mikrofonu jest aktywna."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Permite que o teclado inicie o ditado instantaneamente, sem alternar para o app. O ponto laranja na barra de status é normal — significa que a sessão do microfone está ativa."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Permite tastaturii să înceapă dictarea instantaneu, fără a comuta la aplicație. Punctul portocaliu din bara de stare este normal — înseamnă că sesiunea microfonului este activă."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Umožňuje klávesnici okamžite začať diktovanie bez prepnutia do aplikácie. Oranžová bodka v stavovom riadku je normálna — znamená, že relácia mikrofónu je aktívna."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Låter tangentbordet starta diktering direkt utan att byta till appen. Den orange pricken i statusfältet är normal — den betyder att mikrofonsessionen är aktiv."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Klavyenin uygulamaya geçmeden anında dikte başlatmasını sağlar. Durum çubuğundaki turuncu nokta normaldir — mikrofon oturumunun etkin olduğu anlamına gelir."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Дозволяє клавіатурі миттєво почати диктування без переключення на додаток. Помаранчева крапка в рядку стану — це нормально — вона означає, що сеанс мікрофона активний."
          }
        },
        "zh": {
          "stringUnit": {
            "state": "needs_review",
            "value": "允许键盘即时开始听写，无需切换到应用。状态栏中的橙色圆点是正常的——它表示麦克风会话处于活动状态。"
          }
        }
      }
    },
