    "All recordings from the History tab, including transcription text and audio files stored on this device, will be permanently deleted.": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Все записи из раздела История, включая текст транскрипций и аудиофайлы на этом устройстве, будут удалены безвозвратно."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Všechny nahrávky ze záložky Historie, včetně přepisů a zvukových souborů uložených na tomto zařízení, budou trvale smazány."
          }
        },
        "da": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Alle optagelser fra fanen Historik, inkl. transskriptionstekst og lydfiler gemt på denne enhed, slettes permanent."
          }
        },
        "de": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Alle Aufnahmen aus dem Verlaufs-Tab, einschließlich Transkriptionstexte und auf diesem Gerät gespeicherte Audiodateien, werden dauerhaft gelöscht."
          }
        },
        "el": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Όλες οι εγγραφές από την καρτέλα Ιστορικό, συμπεριλαμβανομένων των κειμένων μεταγραφής και των αρχείων ήχου που είναι αποθηκευμένα σε αυτήν τη συσκευή, θα διαγραφούν μόνιμα."
          }
        },
        "es": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Todas las grabaciones de la pestaña Historial, incluyendo texto de transcripción y archivos de audio almacenados en este dispositivo, se eliminarán permanentemente."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Kaikki Historia-välilehden äänitykset, mukaan lukien litterointitekstit ja laitteelle tallennetut äänitiedostot, poistetaan pysyvästi."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Tous les enregistrements de l'onglet Historique, y compris les textes de transcription et les fichiers audio stockés sur cet appareil, seront supprimés définitivement."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "इतिहास टैब की सभी रिकॉर्डिंग, जिसमें इस डिवाइस पर संग्रहीत ट्रांसक्रिप्शन टेक्स्ट और ऑडियो फ़ाइलें शामिल हैं, स्थायी रूप से हटा दी जाएंगी।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Az Előzmények lap összes felvétele, beleértve az ezen az eszközön tárolt átírási szöveget és hangfájlokat, véglegesen törlődik."
          }
        },
        "it": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Tutte le registrazioni dalla scheda Cronologia, inclusi testi di trascrizione e file audio archiviati su questo dispositivo, verranno eliminati permanentemente."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "履歴タブのすべての録音（このデバイスに保存された文字起こしテキストとオーディオファイルを含む）が完全に削除されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "needs_review",
            "value": "기록 탭의 모든 녹음(이 기기에 저장된 전사 텍스트 및 오디오 파일 포함)이 영구적으로 삭제됩니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Alle opnames van het tabblad Geschiedenis, inclusief transcriptietekst en audiobestanden opgeslagen op dit apparaat, worden permanent verwijderd."
          }
        },
        "no": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Alle opptak fra Historikk-fanen, inkludert transkriberingstekst og lydfiler lagret på denne enheten, vil bli slettet permanent."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Wszystkie nagrania z karty Historia, w tym tekst transkrypcji i pliki audio przechowywane na tym urządzeniu, zostaną trwale usunięte."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Todas as gravações da aba Histórico, incluindo texto de transcrição e arquivos de áudio armazenados neste dispositivo, serão excluídos permanentemente."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Toate înregistrările din fila Istoric, inclusiv textele de transcriere și fișierele audio stocate pe acest dispozitiv, vor fi șterse permanent."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Všetky nahrávky zo záložky História, vrátane prepisov a zvukových súborov uložených na tomto zariadení, budú natrvalo odstránené."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Alla inspelningar från fliken Historik, inklusive transkriptionstext och ljudfiler lagrade på den här enheten, raderas permanent."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Geçmiş sekmesindeki tüm kayıtlar, bu cihazda depolanan transkripsiyon metni ve ses dosyaları dahil, kalıcı olarak silinecektir."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Усі записи з вкладки Історія, включаючи текст транскрипції та аудіофайли, збережені на цьому пристрої, будуть остаточно видалені."
          }
        },
        "zh": {
          "stringUnit": {
            "state": "needs_review",
            "value": "历史记录标签页中的所有录音，包括存储在此设备上的转录文本和音频文件，将被永久删除。"
          }
        }
      }
    },
