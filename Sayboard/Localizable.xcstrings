        },
        "hi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "सबसे हल्का बहुभाषी मॉडल। बुनियादी सटीकता, लेकिन 100 भाषाओं का समर्थन।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "needs_review",
