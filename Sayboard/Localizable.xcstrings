    "wait did you see that? he can't believe it happened": {
      "extractionState": "stale",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "подожди ты это видел? он не может поверить что это случилось"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "needs_review",
            "value": "počkej viděls to? nemůže uvěřit že se to stalo"
          }
        },
        "da": {
          "stringUnit": {
            "state": "needs_review",
            "value": "vent så du det? han kan ikke tro det skete"
          }
        },
        "de": {
          "stringUnit": {
            "state": "needs_review",
            "value": "warte hast du das gesehen? er kanns nicht glauben dass das passiert ist"
          }
        },
        "el": {
          "stringUnit": {
            "state": "needs_review",
            "value": "περίμενε το είδες αυτό; δεν μπορεί να πιστέψει ότι συνέβη"
          }
        },
        "es": {
          "stringUnit": {
            "state": "needs_review",
            "value": "espera viste eso? no puede creer que pasó"
          }
        },
        "fi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "odota näitkö tuon? hän ei voi uskoa että se tapahtui"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "attends t'as vu ça? il n'arrive pas à croire que c'est arrivé"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "रुको तुमने वो देखा? उसे विश्वास नहीं हो रहा कि ऐसा हुआ"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "needs_review",
            "value": "várj láttad? el sem hiszi hogy megtörtént"
          }
        },
        "it": {
          "stringUnit": {
            "state": "needs_review",
            "value": "aspetta hai visto? non riesce a credere che sia successo"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "ちょっと待って見た？彼はそれが起きたなんて信じられない"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "needs_review",
            "value": "잠깐 그거 봤어? 그는 그게 일어났다는 걸 믿을 수 없대"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "needs_review",
            "value": "wacht zag je dat? hij kan niet geloven dat het gebeurd is"
          }
        },
        "no": {
          "stringUnit": {
            "state": "needs_review",
            "value": "vent så du det? han kan ikke tro at det skjedde"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "needs_review",
            "value": "czekaj widziałeś to? nie może uwierzyć że to się stało"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "needs_review",
            "value": "espera você viu isso? ele não consegue acreditar que aconteceu"
          }
        },
        "ro": {
          "stringUnit": {
            "state": "needs_review",
            "value": "stai ai văzut asta? nu poate crede că s-a întâmplat"
          }
        },
        "sk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "počkaj videl si to? nemôže uveriť že sa to stalo"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "needs_review",
            "value": "vänta såg du det? han kan inte tro att det hände"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "bekle gördün mü? olan şeye inanamıyor"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "зачекай ти це бачив? він не може повірити що це сталось"
          }
        },
        "zh": {
          "stringUnit": {
            "state": "needs_review",
            "value": "等等你看到了吗？他不敢相信这居然发生了"
          }
        }
      }
    },
