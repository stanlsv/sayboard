          }
        },
        "fi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Vakio- ja mukautetut kehotteet näkyvät näppäimistön tekoälytoimintojen valikossa."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Les invites standard et personnalisées apparaissent dans le menu d'actions IA du clavier."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "मानक और कस्टम प्रॉम्प्ट कीबोर्ड की AI एक्शन शीट में दिखाई देते हैं।"
