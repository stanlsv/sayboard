    "Microphone access is needed for speech recognition.\n\nAll processing stays on your device.": {
      "comment": "A description of why microphone access is needed for speech recognition, including that all processing happens on the user's device.",
      "extractionState": "stale",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Доступ к микрофону необходим для распознавания речи.\n\nВся обработка происходит на вашем устройстве."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Pro rozpoznávání řeči je potřeba přístup k mikrofonu.\n\nVeškeré zpracování zůstává na vašem zařízení."
          }
        },
        "da": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Mikrofonadgang er nødvendig til talegenkendelse.\n\nAl behandling forbliver på din enhed."
          }
        },
        "de": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Für die Spracherkennung wird Mikrofonzugriff benötigt.\n\nDie gesamte Verarbeitung bleibt auf Ihrem Gerät."
          }
        },
        "el": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Απαιτείται πρόσβαση στο μικρόφωνο για αναγνώριση ομιλίας.\n\nΌλη η επεξεργασία παραμένει στη συσκευή σας."
          }
        },
        "es": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Se necesita acceso al micrófono para el reconocimiento de voz.\n\nTodo el procesamiento permanece en tu dispositivo."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Puheentunnistus vaatii mikrofonin käyttöoikeuden.\n\nKaikki käsittely pysyy laitteellasi."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "L'accès au microphone est nécessaire pour la reconnaissance vocale.\n\nTout le traitement reste sur votre appareil."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "वाक् पहचान के लिए माइक्रोफ़ोन एक्सेस आवश्यक है।\n\nसभी प्रसंस्करण आपके डिवाइस पर रहता है।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "needs_review",
            "value": "A beszédfelismeréshez mikrofon-hozzáférés szükséges.\n\nMinden feldolgozás az eszközén marad."
          }
        },
        "it": {
          "stringUnit": {
            "state": "needs_review",
            "value": "L'accesso al microfono è necessario per il riconoscimento vocale.\n\nTutta l'elaborazione resta sul tuo dispositivo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "音声認識にはマイクへのアクセスが必要です。\n\nすべての処理はデバイス上で行われます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "needs_review",
            "value": "음성 인식을 위해 마이크 접근이 필요합니다.\n\n모든 처리는 기기에서 수행됩니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Microfoontoegang is nodig voor spraakherkenning.\n\nAlle verwerking blijft op uw apparaat."
          }
        },
        "no": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Mikrofontilgang er nødvendig for talegjenkjenning.\n\nAll behandling forblir på enheten din."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Dostęp do mikrofonu jest potrzebny do rozpoznawania mowy.\n\nCałe przetwarzanie pozostaje na Twoim urządzeniu."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "needs_review",
            "value": "O acesso ao microfone é necessário para reconhecimento de fala.\n\nTodo o processamento permanece no seu dispositivo."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Accesul la microfon este necesar pentru recunoașterea vocală.\n\nToate procesările rămân pe dispozitivul dvs."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Na rozpoznávanie reči je potrebný prístup k mikrofónu.\n\nVšetko spracovanie zostáva na vašom zariadení."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Mikrofonåtkomst behövs för taligenkänning.\n\nAll bearbetning stannar på din enhet."
          }
