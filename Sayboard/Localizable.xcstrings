          }
        },
        "el": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Ελαφρύτερο πολυγλωσσικό μοντέλο. Βασική ακρίβεια, αλλά υποστηρίζει 100 γλώσσες."
          }
        },
        "es": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Modelo multilingüe más ligero. Precisión básica, pero compatible con 100 idiomas."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Kevyin monikielinen malli. Perustarkkuus, mutta tukee 100 kieltä."
