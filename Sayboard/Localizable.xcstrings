    "Similar quality to Gemma 3. Stronger in English, weaker multilingual.": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Качество как у Gemma 3. Лучше для английского, слабее мультиязычность."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Podobná kvalita jako Gemma 3. Silnější v angličtině, slabší vícejazyčně."
          }
        },
        "da": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Lignende kvalitet som Gemma 3. Stærkere på engelsk, svagere flersproget."
          }
        },
        "de": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Ähnliche Qualität wie Gemma 3. Stärker auf Englisch, schwächer mehrsprachig."
          }
        },
        "el": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Παρόμοια ποιότητα με το Gemma 3. Ισχυρότερο στα αγγλικά, ασθενέστερο πολυγλωσσικά."
          }
        },
        "es": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Calidad similar a Gemma 3. Más fuerte en inglés, más débil en multilingüe."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Samanlainen laatu kuin Gemma 3. Vahvempi englanniksi, heikompi monikielisesti."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Qualité similaire à Gemma 3. Plus fort en anglais, plus faible en multilingue."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Gemma 3 जैसी गुणवत्ता। अंग्रेज़ी में मजबूत, बहुभाषी में कमजोर।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Hasonló minőség, mint a Gemma 3. Erősebb angolul, gyengébb többnyelvűen."
          }
        },
        "it": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Qualità simile a Gemma 3. Più forte in inglese, più debole nel multilingue."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Gemma 3と同等の品質。英語に強く、多言語は弱め。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Gemma 3과 비슷한 품질. 영어에 강하고 다국어에 약함."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Vergelijkbare kwaliteit als Gemma 3. Sterker in Engels, zwakker meertalig."
          }
        },
        "no": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Lignende kvalitet som Gemma 3. Sterkere på engelsk, svakere flerspråklig."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Podobna jakość do Gemma 3. Lepszy w angielskim, słabszy wielojęzycznie."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Qualidade semelhante ao Gemma 3. Mais forte em inglês, mais fraco em multilíngue."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Calitate similară cu Gemma 3. Mai puternic în engleză, mai slab multilingv."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Podobná kvalita ako Gemma 3. Silnejší v angličtine, slabší viacjazyčne."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Liknande kvalitet som Gemma 3. Starkare på engelska, svagare flerspråkigt."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Gemma 3 ile benzer kalite. İngilizcede daha güçlü, çok dilde daha zayıf."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Подібна якість до Gemma 3. Сильніший в англійській, слабший багатомовно."
          }
        },
        "zh": {
          "stringUnit": {
            "state": "needs_review",
            "value": "与Gemma 3质量相似。英语更强，多语言较弱。"
          }
        }
      }
    },
