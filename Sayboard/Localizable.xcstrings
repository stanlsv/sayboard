    "You can enable this later in Settings.": {
      "comment": "A message explaining that the user can enable microphone access in settings.",
      "extractionState": "stale",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вы можете включить это позже в Настройках."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Toto můžete povolit později v Nastavení."
          }
        },
        "da": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Du kan aktivere dette senere i Indstillinger."
          }
        },
        "de": {
          "stringUnit": {
