        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "最高品質のモデル。最高の多言語サポート、ただし最も遅い。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "needs_review",
            "value": "최고 품질 모델. 최고의 다국어 지원이지만 가장 느림."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Model van hoogste kwaliteit. Beste meertalige ondersteuning, maar langzaamst."
          }
        },
        "no": {
          "stringUnit": {
