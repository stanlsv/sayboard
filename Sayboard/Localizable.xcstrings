    "Lightest multilingual model. Basic accuracy, but supports 100 languages.": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Самая легкая мультиязычная модель. Базовая точность, но поддержка 100 языков."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Nejlehčí vícejazyčný model. Základní přesnost, ale podporuje 100 jazyků."
          }
        },
        "da": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Letteste flersprogede model. Grundlæggende nøjagtighed, men understøtter 100 sprog."
          }
        },
        "de": {
          "stringUnit": {
            "state": "needs_review",
