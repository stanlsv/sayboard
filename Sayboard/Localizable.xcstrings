    "Long-pressing the AI button on keyboard runs this action directly, skipping the action list.": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Долгое нажатие на кнопку ИИ на клавиатуре сразу запускает это действие, минуя список."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Dlouhým stisknutím tlačítka AI na klávesnici se tato akce spustí přímo, bez zobrazení seznamu akcí."
          }
        },
        "da": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Ved at holde AI-knappen på tastaturet nede køres denne handling direkte, uden at vise handlingslisten."
          }
        },
        "de": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Langes Drücken der AI-Taste auf der Tastatur führt diese Aktion direkt aus, ohne die Aktionsliste anzuzeigen."
          }
        },
        "el": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Πατώντας παρατεταμένα το κουμπί AI στο πληκτρολόγιο εκτελείται αυτή η ενέργεια απευθείας, παρακάμπτοντας τη λίστα ενεργειών."
          }
        },
        "es": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Mantener presionado el botón de IA en el teclado ejecuta esta acción directamente, omitiendo la lista de acciones."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Pitkä painallus tekoälypainikkeesta näppäimistöllä suorittaa tämän toiminnon suoraan, ohittaen toimintoluettelon."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Un appui long sur le bouton IA du clavier exécute cette action directement, sans passer par la liste d'actions."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "कीबोर्ड पर AI बटन को लंबे समय तक दबाने से यह क्रिया सीधे चलती है, क्रिया सूची को छोड़कर।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Az AI gomb hosszú lenyomása a billentyűzeten közvetlenül futtatja ezt a műveletet, kihagyva a műveleti listát."
          }
        },
        "it": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Premendo a lungo il pulsante AI sulla tastiera si esegue questa azione direttamente, saltando la lista delle azioni."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "キーボードのAIボタンを長押しすると、アクションリストをスキップしてこのアクションが直接実行されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "needs_review",
            "value": "키보드의 AI 버튼을 길게 누르면 작업 목록을 건너뛰고 이 작업이 바로 실행됩니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Lang indrukken van de AI-knop op het toetsenbord voert deze actie direct uit, zonder de actielijst."
          }
        },
        "no": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Å holde inne AI-knappen på tastaturet kjører denne handlingen direkte, uten å vise handlingslisten."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Długie naciśnięcie przycisku AI na klawiaturze uruchamia tę akcję bezpośrednio, pomijając listę akcji."
          }
        },
        "pt": {
          "stringUnit": {
