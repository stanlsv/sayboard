    "Enable microphone access so Sayboard can hear you. Your audio never leaves your device.": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Разрешите доступ к микрофону, чтобы Sayboard мог вас слышать. Аудио никогда не покидает ваше устройство."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Povolte přístup k mikrofonu, aby vás Sayboard mohl slyšet. Váš zvuk nikdy neopustí vaše zařízení."
          }
        },
        "da": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Aktiver mikrofonadgang, så Sayboard kan høre dig. Din lyd forlader aldrig din enhed."
          }
        },
        "de": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Aktivieren Sie den Mikrofonzugriff, damit Sayboard Sie hören kann. Ihre Audiodaten verlassen niemals Ihr Gerät."
          }
        },
        "el": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Ενεργοποιήστε την πρόσβαση στο μικρόφωνο ώστε το Sayboard να σας ακούει. Ο ήχος σας δεν φεύγει ποτέ από τη συσκευή σας."
          }
        },
        "es": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Activa el acceso al micrófono para que Sayboard pueda escucharte. Tu audio nunca sale de tu dispositivo."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Ota mikrofonin käyttöoikeus käyttöön, jotta Sayboard voi kuulla sinut. Äänesi ei koskaan poistu laitteeltasi."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Activez l'accès au microphone pour que Sayboard puisse vous entendre. Votre audio ne quitte jamais votre appareil."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "माइक्रोफ़ोन एक्सेस सक्षम करें ताकि Sayboard आपको सुन सके। आपका ऑडियो कभी आपके डिवाइस से बाहर नहीं जाता।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Engedélyezze a mikrofon-hozzáférést, hogy a Sayboard hallja Önt. A hangfelvétel soha nem hagyja el az eszközét."
          }
        },
        "it": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Abilita l'accesso al microfono affinché Sayboard possa sentirti. Il tuo audio non lascia mai il tuo dispositivo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Sayboardがあなたの声を聞けるようにマイクへのアクセスを有効にしてください。音声データはデバイスから外に出ることはありません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Sayboard가 들을 수 있도록 마이크 접근을 허용하세요. 오디오는 기기 밖으로 나가지 않습니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Schakel microfoontoegang in zodat Sayboard u kan horen. Uw audio verlaat nooit uw apparaat."
          }
        },
        "no": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Aktiver mikrofontilgang slik at Sayboard kan høre deg. Lyden din forlater aldri enheten din."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Włącz dostęp do mikrofonu, aby Sayboard mógł Cię słyszeć. Twój dźwięk nigdy nie opuszcza Twojego urządzenia."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Ative o acesso ao microfone para que o Sayboard possa ouvi-lo. Seu áudio nunca sai do seu dispositivo."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Activați accesul la microfon pentru ca Sayboard să vă poată auzi. Sunetul dvs. nu părăsește niciodată dispozitivul."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Povoľte prístup k mikrofónu, aby vás Sayboard mohol počuť. Váš zvuk nikdy neopustí vaše zariadenie."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Aktivera mikrofonåtkomst så att Sayboard kan höra dig. Ditt ljud lämnar aldrig din enhet."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Sayboard'un sizi duyabilmesi için mikrofon erişimini etkinleştirin. Sesiniz asla cihazınızdan çıkmaz."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Увімкніть доступ до мікрофона, щоб Sayboard міг вас чути. Ваше аудіо ніколи не залишає ваш пристрій."
          }
        },
        "zh": {
          "stringUnit": {
            "state": "needs_review",
            "value": "启用麦克风权限以便Sayboard能听到您。您的音频永远不会离开您的设备。"
          }
        }
      }
    },
