    "Compiled models will be removed from cache. Recompilation will be required on next use, which may take up to a minute.": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Скомпилированные модели будут удалены из кэша. При следующем использовании потребуется повторная компиляция — это может занять до минуты."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Zkompilované modely budou odstraněny z mezipaměti. Při dalším použití bude nutná rekompilace, která může trvat až minutu."
          }
        },
        "da": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Kompilerede modeller fjernes fra cachen. Genkompilering vil være nødvendig ved næste brug, hvilket kan tage op til et minut."
          }
        },
        "de": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Kompilierte Modelle werden aus dem Cache entfernt. Bei der nächsten Verwendung ist eine Neukompilierung erforderlich, die bis zu einer Minute dauern kann."
          }
        },
        "el": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Τα μεταγλωττισμένα μοντέλα θα αφαιρεθούν από την κρυφή μνήμη. Θα απαιτηθεί εκ νέου μεταγλώττιση κατά την επόμενη χρήση, η οποία μπορεί να διαρκέσει έως ένα λεπτό."
          }
        },
        "es": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Los modelos compilados se eliminarán del caché. Se requerirá recompilación en el próximo uso, lo cual puede tardar hasta un minuto."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Käännetyt mallit poistetaan välimuistista. Uudelleenkäännös vaaditaan seuraavalla kerralla, mikä voi kestää jopa minuutin."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Les modèles compilés seront supprimés du cache. Une recompilation sera nécessaire lors de la prochaine utilisation, ce qui peut prendre jusqu'à une minute."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "संकलित मॉडल कैश से हटा दिए जाएंगे। अगले उपयोग पर पुन: संकलन आवश्यक होगा, जिसमें एक मिनट तक लग सकता है।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "needs_review",
            "value": "A lefordított modellek eltávolításra kerülnek a gyorsítótárból. A következő használatkor újrafordítás szükséges, ami akár egy percig is tarthat."
          }
        },
        "it": {
          "stringUnit": {
            "state": "needs_review",
            "value": "I modelli compilati verranno rimossi dalla cache. Sarà necessaria la ricompilazione al prossimo utilizzo, che potrebbe richiedere fino a un minuto."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "コンパイル済みモデルがキャッシュから削除されます。次回使用時に再コンパイルが必要で、最大1分かかる場合があります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "needs_review",
            "value": "컴파일된 모델이 캐시에서 제거됩니다. 다음 사용 시 재컴파일이 필요하며, 최대 1분이 소요될 수 있습니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Gecompileerde modellen worden uit de cache verwijderd. Hercompilatie is nodig bij volgend gebruik, wat tot een minuut kan duren."
          }
        },
        "no": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Kompilerte modeller fjernes fra bufferen. Ny kompilering kreves ved neste bruk, noe som kan ta opptil ett minutt."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Skompilowane modele zostaną usunięte z pamięci podręcznej. Przy następnym użyciu wymagana będzie rekompilacja, która może potrwać do minuty."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Os modelos compilados serão removidos do cache. Será necessária recompilação no próximo uso, o que pode levar até um minuto."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Modelele compilate vor fi eliminate din cache. La următoarea utilizare va fi necesară recompilarea, care poate dura până la un minut."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Skompilované modely budú odstránené z vyrovnávacej pamäte. Pri ďalšom použití bude potrebná rekompilácia, ktorá môže trvať až minútu."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Kompilerade modeller tas bort från cachen. Omkompilering krävs vid nästa användning, vilket kan ta upp till en minut."
          }
        },
        "tr": {
          "stringUnit": {
