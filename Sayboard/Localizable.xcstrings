    "Standard and custom prompts appear in the keyboard's AI action sheet.": {
      "extractionState": "stale",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Стандартные и пользовательские промпты отображаются в списке AI-действий клавиатуры."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Standardní a vlastní výzvy se zobrazí v nabídce akcí AI klávesnice."
          }
        },
        "da": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Standard- og brugerdefinerede prompts vises i tastaturets AI-handlingsark."
          }
        },
        "de": {
          "stringUnit": {
            "state": "needs_review",
