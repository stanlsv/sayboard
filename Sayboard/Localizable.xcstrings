    "active_session_tip_message": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The orange indicator means the mic session is ready for instant dictation. No hidden recording — the mic only activates when you press record. App switching is required because iOS blocks mic access in keyboard extensions. Adjust “Auto-Stop” to control how often this happens. Battery impact is minimal."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Оранжевый индикатор означает, что сессия микрофона готова для мгновенной диктовки. Скрытой записи нет — микрофон включается только при нажатии кнопки записи. Переключение в приложение необходимо, так как iOS блокирует доступ к микрофону в расширениях клавиатуры. Настройте «Автоотключение», чтобы контролировать частоту переключений. Расход батареи минимален."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "active_session_tip_message"
          }
