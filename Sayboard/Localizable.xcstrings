    "Not enough storage space. Free up space and try again.": {
      "comment": "Error when model download fails because device storage is full",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Недостаточно места. Освободите память и попробуйте снова."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Nedostatek místa. Uvolněte místo a zkuste to znovu."
          }
        },
        "da": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Ikke nok lagerplads. Frigør plads og prøv igen."
          }
        },
        "de": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Nicht genügend Speicherplatz. Geben Sie Speicher frei und versuchen Sie es erneut."
          }
        },
        "el": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Δεν υπάρχει αρκετός αποθηκευτικός χώρος. Ελευθερώστε χώρο και δοκιμάστε ξανά."
          }
        },
        "es": {
          "stringUnit": {
            "state": "needs_review",
            "value": "No hay suficiente espacio de almacenamiento. Libera espacio e inténtalo de nuevo."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Tallennustila ei riitä. Vapauta tilaa ja yritä uudelleen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Espace de stockage insuffisant. Libérez de l'espace et réessayez."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "पर्याप्त स्टोरेज नहीं है। जगह खाली करें और पुनः प्रयास करें।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Nincs elég tárhely. Szabadítson fel helyet, és próbálja újra."
          }
        },
        "it": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Spazio di archiviazione insufficiente. Libera spazio e riprova."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "ストレージ空間が不足しています。空きを作ってもう一度お試しください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "needs_review",
            "value": "저장 공간이 부족합니다. 공간을 확보하고 다시 시도하세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Niet genoeg opslagruimte. Maak ruimte vrij en probeer het opnieuw."
          }
        },
        "no": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Ikke nok lagringsplass. Frigjør plass og prøv igjen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Za mało miejsca. Zwolnij miejsce i spróbuj ponownie."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Espaço de armazenamento insuficiente. Libere espaço e tente novamente."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Spațiu de stocare insuficient. Eliberează spațiu și încearcă din nou."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Nedostatok miesta. Uvoľnite miesto a skúste to znova."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Inte tillräckligt med lagringsutrymme. Frigör utrymme och försök igen."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Yeterli depolama alanı yok. Alan açın ve tekrar deneyin."
          }
        },
        "uk": {
          "stringUnit": {
