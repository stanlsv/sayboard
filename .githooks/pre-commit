#!/usr/bin/env bash
set -euo pipefail

# Pre-commit hook: SwiftFormat + SwiftLint validation
# Blocks commits if staged Swift files have formatting or lint violations.

STAGED_SWIFT_FILES=$(git diff --cached --name-only --diff-filter=ACM -- '*.swift')

if [ -z "$STAGED_SWIFT_FILES" ]; then
  exit 0
fi

PASS=true

# --- SwiftFormat check (lint-only, no modifications) ---
if command -v swiftformat >/dev/null 2>&1; then
  echo "Running SwiftFormat lint..."
  echo "$STAGED_SWIFT_FILES" | while IFS= read -r file; do
    if [ -f "$file" ]; then
      if ! swiftformat --lint --quiet "$file" 2>/dev/null; then
        echo "SwiftFormat: $file needs formatting. Run: swiftformat $file"
        # Signal failure via temp file since we're in a subshell
        touch /tmp/.sayboard-precommit-fail
      fi
    fi
  done

  if [ -f /tmp/.sayboard-precommit-fail ]; then
    rm -f /tmp/.sayboard-precommit-fail
    PASS=false
  fi
else
  echo "warning: SwiftFormat not installed. Run: brew install swiftformat"
fi

# --- SwiftLint check ---
if command -v swiftlint >/dev/null 2>&1; then
  echo "Running SwiftLint..."
  LINT_RESULT=0
  echo "$STAGED_SWIFT_FILES" | xargs swiftlint lint --strict --quiet 2>/dev/null || LINT_RESULT=$?

  if [ "$LINT_RESULT" -ne 0 ]; then
    echo "SwiftLint: found violations. Fix them before committing."
    PASS=false
  fi
else
  echo "warning: SwiftLint not installed. Run: brew install swiftlint"
fi

if [ "$PASS" = false ]; then
  echo ""
  echo "Commit blocked. Fix the issues above, then try again."
  echo "  Auto-format: swiftformat ."
  echo "  Check lint:  swiftlint lint --strict"
  exit 1
fi
